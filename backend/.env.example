# Backend service configuration
PORT=4000

# Use the exact MongoDB connection string copied from Atlas.
# If Render cannot resolve an mongodb+srv:// URI, use Atlas' non-SRV mongodb:// connection string instead.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database-name>?retryWrites=true&w=majority

JWT_SECRET=replace_with_a_long_random_secret
STRIPE_SECRET_KEY=sk_test_replace_me

# Public URL of the customer frontend. Used for Stripe Checkout redirects.
FRONTEND_URL=http://localhost:5173
